MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
DATABASE_NAME=form_db
HOST=0.0.0.0
PORT=8002
ENV=production
CORS_ALLOW_ORIGINS=https://<your-frontend-project>.vercel.app
CORS_ALLOW_ORIGIN_REGEX=^$
# Generate a secure random token: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_TOKEN=<strong-random-token>
# User service proxy (must match FORM_SERVICE_TOKEN on user service)
USER_SERVICE_URL=https://<your-user-service>.vercel.app
USER_SERVICE_TOKEN=<must-match-user-service-FORM_SERVICE_TOKEN>
