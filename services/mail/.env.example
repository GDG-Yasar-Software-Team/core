# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=gdg_db
CAMPAIGNS_COLLECTION=mails

# User Service Configuration
USER_SERVICE_URL=http://localhost:8001
USER_SERVICE_TOKEN=your-user-service-token-here
USER_SERVICE_TIMEOUT=30.0

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_ADDRESS=
SMTP_PASSWORD=

# Security
UNSUBSCRIBE_SECRET_KEY=your-secret-key-here

# Base URL for unsubscribe links
BASE_URL=http://localhost:8000

# Environment
ENV=development
