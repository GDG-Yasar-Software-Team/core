# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=gdg_db
CAMPAIGNS_COLLECTION=mails
HOST=0.0.0.0
PORT=8000

# User Service Configuration
USER_SERVICE_URL=http://localhost:8001
USER_SERVICE_TOKEN=your-user-service-token-here
USER_SERVICE_TIMEOUT=30.0

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_ADDRESS=
SMTP_PASSWORD=

# Security
UNSUBSCRIBE_SECRET_KEY=your-secret-key-here

# Base URL for unsubscribe links
BASE_URL=http://localhost:8000

# Admin Authentication
ADMIN_API_TOKEN=your-admin-token-here

# Auto-fail campaigns stuck in in_progress (minutes, 0 = off)
STALE_IN_PROGRESS_MINUTES=120

# CORS (comma-separated for multiple origins)
ALLOWED_ORIGINS=["http://localhost:3001"]

# Environment
ENV=development
