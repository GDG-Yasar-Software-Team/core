# MongoDB (production cluster)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
DATABASE_NAME=gdg_db
CAMPAIGNS_COLLECTION=mails
HOST=0.0.0.0
PORT=8000

# User service (USER_SERVICE_TOKEN must match MAIL_SERVICE_TOKEN on user service)
USER_SERVICE_URL=https://<your-user-service>.vercel.app
USER_SERVICE_TOKEN=<must-match-user-service-MAIL_SERVICE_TOKEN>
USER_SERVICE_TIMEOUT=30.0

# SMTP (production sender)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_ADDRESS=noreply@<your-domain>
SMTP_PASSWORD=<smtp-or-app-password>

# Public base URL of this mail API (unsubscribe links, must be HTTPS in production)
BASE_URL=https://<your-mail-service>.vercel.app

# Secrets — generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
UNSUBSCRIBE_SECRET_KEY=<strong-random-secret>
ADMIN_API_TOKEN=<strong-random-token>

# CORS: mail admin frontend origin(s), JSON array
ALLOWED_ORIGINS=["https://<your-mail-frontend>.vercel.app"]

# Optional tuning (defaults are usually fine)
# STALE_IN_PROGRESS_MINUTES=120
# RATE_LIMIT_MIN_DELAY=2.0
# RATE_LIMIT_MAX_DELAY=6.0
# SCHEDULER_CHECK_INTERVAL_MINUTES=1
# PROGRESS_UPDATE_INTERVAL=10

ENV=production
