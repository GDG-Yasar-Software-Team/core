# MongoDB Configuration
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
DATABASE_NAME=users
USERS_COLLECTION=users
HOST=0.0.0.0
PORT=8001

# Service API Tokens (for internal service authentication)
FORM_SERVICE_TOKEN=<strong-random-token-for-form-service>
MAIL_SERVICE_TOKEN=<strong-random-token-for-mail-service>
FORM_FRONTEND_TOKEN=<strong-random-token-for-frontend>

# Environment
ENV=production
CORS_ALLOW_ORIGINS=https://<your-frontend-project>.vercel.app
CORS_ALLOW_ORIGIN_REGEX=^$
