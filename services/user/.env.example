# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=gdg_db
USERS_COLLECTION=users
HOST=0.0.0.0
PORT=8001

# Service API Tokens (for internal service authentication)
FORM_SERVICE_TOKEN=your-form-service-token
MAIL_SERVICE_TOKEN=your-mail-service-token
FORM_FRONTEND_TOKEN=your-form-frontend-token

# Environment
ENV=development
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
